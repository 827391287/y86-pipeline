# Test: rmmovq (store register to memory)
# Covers: write to data memory, then read back to verify
#
# Expected result:
#   %rcx = 42  (store 42 to mem[200], load it back)

    irmovq $42,  %rax
    irmovq $200, %rbx
    rmmovq %rax, 0(%rbx)    # mem[200] = 42
    irmovq $0,   %rcx
    mrmovq 0(%rbx), %rcx    # %rcx = mem[200] = 42
    halt
