# Test: pushq and popq (stack operations)
# Covers: stack pointer decrement/increment, memory write/read via stack
#
# Expected result:
#   %rbx = 42   (value pushed then popped)
#   %rsp = 512  (restored to initial value after push+pop)

    irmovq $512, %rsp    # init stack pointer
    irmovq $42,  %rax
    irmovq $0,   %rbx
    pushq  %rax          # %rsp = 504, mem[504] = 42
    popq   %rbx          # %rbx = mem[504] = 42, %rsp = 512
    halt
