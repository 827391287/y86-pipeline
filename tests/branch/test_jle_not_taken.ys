# Test: jle branch NOT TAKEN (misprediction recovery)
# Covers: pipeline predicts taken, detects misprediction in E stage,
#         flushes 2 speculatively fetched instructions, recovers correctly
#
# Condition: subq %rax, %rbx computes rbx - rax = 5 - 3 = 2
#   SF=0, OF=0  =>  SF^OF = 0, ZF=0  =>  jle NOT TAKEN
#
# Pipeline behavior:
#   Fetch: predicts jle taken, fetches from 'taken' label (wrong)
#   Execute: detects not-taken, sets D_bubble + E_bubble
#   Result: 2 bubble NOPs inserted, correct path resumes
#
# Expected result:
#   %rcx = 99  (not-taken path executed, taken path skipped)

    irmovq $3,  %rax
    irmovq $5,  %rbx
    irmovq $0,  %rcx
    subq   %rax, %rbx    # rbx = 5 - 3 = 2, positive => jle NOT taken
    jle    taken
    irmovq $99, %rcx     # executed (correct path)
    jmp    done
taken:
    irmovq $1,  %rcx     # skipped (wrong path, flushed by pipeline)
done:
    halt
